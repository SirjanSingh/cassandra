# Cassandra environment template. Copy to .env and fill in.
# Real secrets live in Secret Manager in deployed environments (NFR-4); .env is local-only.

# --- Google Cloud / Gemini 3 ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GEMINI_MODEL=gemini-3-pro            # SPIKE-RECONCILE: confirm exact Gemini 3 model id in your region

# --- Arize Phoenix (partner MCP) ---
PHOENIX_BASE_URL=https://app.phoenix.arize.com
PHOENIX_API_KEY=replace-me
# How Cassandra reaches the Phoenix MCP server. Default = the official npx package.
# SPIKE-RECONCILE: confirm command/transport during the Day-1 MCP enumeration spike.
PHOENIX_MCP_COMMAND=npx
PHOENIX_MCP_ARGS=-y,@arizeai/phoenix-mcp@latest

# Phoenix project names
PATIENT_PROJECT=patient-prod         # the victim agent's traces
META_PROJECT=cassandra-meta          # Cassandra's own self-observability (NFR-3)

# --- Cassandra tuning ---
POLL_INTERVAL_SECONDS=60             # FR-W1
DIAGNOSIS_CONFIDENCE_THRESHOLD=0.7   # FR-D3
SYNTH_DATASET_SIZE=12                # FR-S1

# --- Introspection / on-product depth ---
SELF_TRACE_ENABLED=true              # trace Cassandra's own reasoning into META_PROJECT
PHOENIX_EXPERIMENTS_ENABLED=false    # also register the A/B as a real Phoenix experiment

# --- State backend ---
STATE_BACKEND=firestore              # firestore | gcs | local
FIRESTORE_COLLECTION=cassandra_state

# --- Dashboard ---
DASHBOARD_PORT=8085
PATIENT_ENDPOINT=http://localhost:8082/chat

# --- Supervised agent ("Patient") integration — bring your own agent ---
# BASELINE_PROMPT_FILE: file holding the supervised agent's CURRENT system prompt.
# Resolution order (cassandra/baseline.py): this file -> the failing span's
# llm.input_messages system message -> the bundled demo ShopBot prompt.
# BASELINE_PROMPT_FILE=prompts/system_prompt.txt
# PATIENT_PROMPT_NAME: Phoenix prompt name candidate patches are versioned under.
# PATIENT_PROMPT_NAME=patient-shopbot-system

# --- Security ---
# Shared secret for the Patient's system_override path. REQUIRED on any public
# deployment (set the same value on both the dashboard/Cassandra and Patient services,
# via Secret Manager). Leave unset for local dev.
# REPLAY_SHARED_SECRET=change-me
